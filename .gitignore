# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store

# Secrets — TTS pipeline API keys (NEVER commit)
.env
**/.env
*.mp3.partial
__pycache__/

# TTS run logs (progress.jsonl / failures.log)
tools/tts/logs/

# Heavy generated/source media — kept out of the repo to stay lightweight.
# Source PDFs (1.1GB) and generated lecture audio (~600MB) are bundled into the
# APK at build time from local disk; they are not needed in version control.
assets/pdf/
assets/audio/
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
