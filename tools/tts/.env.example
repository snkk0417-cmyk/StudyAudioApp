# StudyAudioApp — TTS configuration
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Paste your OpenAI API key below.
# 3. .env is gitignored and must NEVER be committed.

# Required: your OpenAI API key (only used when actually generating audio).
OPENAI_API_KEY=sk-your-key-here

# --- Optional overrides (sensible defaults are built in) ---

# TTS model. Options include: gpt-4o-mini-tts (default), tts-1, tts-1-hd
TTS_MODEL=gpt-4o-mini-tts

# Voice. Good natural-Japanese choices: nova, shimmer, alloy, fable, onyx, echo
TTS_VOICE=nova

# Output audio format (mp3 keeps app assets small).
TTS_FORMAT=mp3

# Playback speed baked into the audio (0.25–4.0). Leave at 1.0; the app has its own
# speed control. Only supported by some models.
TTS_SPEED=1.0

# Optional steering instructions for gpt-4o-mini-tts (tone/pace). Japanese is fine.
# Example: 落ち着いた声で、建築の講師が後輩に教えるように、明瞭に話してください。
TTS_INSTRUCTIONS=落ち着いた声で、建築士試験の講師が丁寧に解説するように、明瞭にゆっくり話してください。

# Price USD per 1,000,000 input characters, used ONLY for the cost estimate.
# Verify against current OpenAI pricing — this is an estimate, not a billing source.
#   tts-1 ~= 15.00, tts-1-hd ~= 30.00, gpt-4o-mini-tts ~= 12.00 (approx, per-char basis)
TTS_PRICE_PER_1M_CHARS=12.00
